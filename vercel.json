{
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "crons": {
    "period": "1 day",
    "path": "/api/cron/dunning",
    "method": "POST"
  },
  "cronJobs": [
    {
      "path": "/api/cron/dunning",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/recurring-invoices",
      "schedule": "0 7 1 * *"
    }
  ]
}
