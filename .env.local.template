# =====================================================
# ARIS Dashboard - Environment Variables
# =====================================================
# Kopiere diese Datei zu .env.local und passe die Werte an

# =====================================================
# SUPABASE (REQUIRED)
# =====================================================
# Deine Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (für Client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (NUR für Server-Side!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# =====================================================
# SENTRY (Optional - Error Tracking)
# =====================================================
SENTRY_DSN=https://your-dsn@sentry.io/project
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_org
SENTRY_PROJECT=your_project

# =====================================================
# RESEND (Für Emails)
# =====================================================
RESEND_API_KEY=re_your_api_key

# =====================================================
# CRON (API Key für automatisierte Aufgaben)
# =====================================================
CRON_API_KEY=sk_cron_generate_a_secure_random_key

# =====================================================
# URLs (WICHTIG!)
# =====================================================
# Basis-URL für Production Links (in Vercel setzen!)
NEXT_PUBLIC_BASE_URL=https://your-production-domain.com
